[init]
	defaultBranch = main
[user]
	email = piero.capelo@proton.me
	name = Piero Capelo

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true

[merge]
	conflictStyle = diff3

[diff]
	colorMoved = default
[mergetool "bc"]
	path = /usr/bin/bc
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
